{
  "manifest_version": 3,
  "name": "Custom CSS Injector – custom styles per domain",
  "version": "2.1.2",
  "description": "Inject custom CSS per domain. A minimalist, ultra-efficient extension to style any website without bloat or heavy features.",
  "minimum_chrome_version": "111",
  "permissions": ["storage", "tabs", "scripting", "activeTab"],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self'; font-src 'self'; connect-src 'none';"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "*://chrome.google.com/webstore*",
        "*://chromewebstore.google.com/*",
        "*://microsoftedge.microsoft.com/addons*",
        "*://microsoftedge.microsoft.com/*/addons*"
      ],
      "js": ["shadow-dom-bridge.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "world": "MAIN"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "*://chrome.google.com/webstore*",
        "*://chromewebstore.google.com/*",
        "*://microsoftedge.microsoft.com/addons*",
        "*://microsoftedge.microsoft.com/*/addons*"
      ],
      "js": ["utils.js", "constants.js", "content-script.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ]
}
